{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["vitest/globals", "vite/client"]
  },
  "include": ["convex/**/*.test.ts"]
}
